# 1. Default options
{exe} old new
>>>
>>>2
>>>= 0

# 2. Different block size
{exe} --block-size 100 old new
>>>
>>>2
>>>= 0

# 3. Don't print diff. Just inform if dirs differ.
{exe} --brief old new
>>>
>>>2
>>>= 0

# 4. 2 + 3
{exe} --block-size 100 --brief old new
>>>
>>>2
>>>= 0

# 5. Negative block size
{exe} --block-size -5 old new
>>>
>>>2
{exe}: CLI error: invalid block size: -5
>>>= 2

# 6. Text block size
{exe} --block-size five old new
>>>
>>>2
{exe}: CLI error: invalid block size: five
>>>= 2

# 7. Zero block size
{exe} --block-size 0 old new
>>>
>>>2
{exe}: CLI error: invalid block size: 0
>>>= 2
